# Données brutes (volumineuses, non versionnées — régénérables)
02_data/raw/blast_db/
02_data/raw/*.gz
02_data/raw/*.fasta

# Fichiers intermédiaires générés par le pipeline (régénérables avec make excel)
# Le .gitkeep preserve la structure des répertoires dans git
02_data/processed/*
!02_data/processed/.gitkeep
02_data/annotations/*
!02_data/annotations/.gitkeep
02_data/clinvar_exports/*
!02_data/clinvar_exports/.gitkeep

# Checkpoints pipeline
.pipeline_checkpoint.json

# Résultats BLAST bruts
blast_genome_results_raw/
blast_genome_cache/
*.asn

# Logs
*.log

# Fichiers PDF de publications (copyright — non redistribuables)
